# Environment Variables Template
# Copy this file to .env and fill in your values

# ===== LLM Configuration =====
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
MODEL=glm-5

# ===== Database Configuration =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=medical_user
DB_PASSWORD=your_secure_password
DB_NAME=medical_agent

# ===== Redis Configuration =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ===== Memory Configuration (Mem0) =====
MEM0_API_KEY=your_mem0_api_key
VECTOR_STORE_TYPE=mem0

# ===== Application Configuration =====
APP_NAME=Medical Agent
APP_VERSION=0.1.0
DEBUG=False
LOG_LEVEL=INFO

# ===== CORS Configuration =====
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ===== JWT Configuration =====
JWT_SECRET_KEY=your_jwt_secret_key_change_me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ===== Skill Executor Configuration =====
# Available backends: subprocess (default), msagent, auto
SKILL_EXECUTOR_BACKEND=subprocess
SKILL_EXECUTOR_TIMEOUT=30
# Set to true to enable sandbox isolation (requires MS-Agent and Docker)
SKILL_EXECUTOR_USE_SANDBOX=false
# Optional: LLM model for MS-Agent autonomous planning
# SKILL_EXECUTOR_LLM_MODEL=claude-sonnet-4-6
